---
import RiskMeter from './RiskMeter.astro';

interface Props {
  station: number;
  title: string;
  mentalModel: string;
  risk: number;
  altitude: string;
  status: 'published' | 'locked';
  href?: string;
  lang?: 'zh' | 'en';
}
const { station, title, mentalModel, risk, altitude, status, href, lang = 'zh' } = Astro.props;
const locked = status === 'locked';
const Tag = locked ? 'div' : 'a';
const lockedLabel = lang === 'zh' ? '待解锁' : 'Locked';
const num = String(station).padStart(2, '0');
---
<Tag class:list={['station-card', { locked }]} href={locked ? undefined : href}>
  <span class="st-badge">{num}</span>
  <div class="st-body">
    <h3 class="st-title">{title}</h3>
    <p class="st-mm">{mentalModel}</p>
    <div class="st-meta">
      {locked ? (
        <span class="st-locked">🔒 {lockedLabel}</span>
      ) : (
        <Fragment>
          <span class="st-alt">{altitude}</span>
          <RiskMeter value={risk} />
        </Fragment>
      )}
    </div>
  </div>
  {!locked && <span class="st-go">→</span>}
</Tag>

<style>
  .station-card {
    display: flex; align-items: stretch;
    border-radius: var(--radius);
    text-decoration: none;
    overflow: hidden;
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }
  /* 激活的站 = 暖琥珀,一份温度在冷蓝图里 */
  a.station-card {
    background: linear-gradient(100deg, rgba(244,161,74,.07), var(--card) 46%);
    border: 1px solid rgba(244,161,74,.34);
    box-shadow: var(--shadow-soft);
  }
  a.station-card:hover {
    transform: translateY(-3px);
    border-color: var(--amber);
    box-shadow: 0 22px 50px -22px rgba(244,161,74,.45);
  }
  /* 未解锁 = 冷蓝图虚线、低调 */
  .station-card.locked {
    background: rgba(92,200,232,.015);
    border: 1px dashed var(--line);
  }

  .st-badge {
    font-family: var(--display); font-weight: 600; font-size: 2.5rem; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    min-width: 88px; color: var(--amber);
    border-right: 1px solid rgba(244,161,74,.22);
  }
  .locked .st-badge {
    color: var(--ink-faint); border-right: 1px dashed var(--line);
  }

  .st-body { padding: 16px 22px; flex: 1; display: flex; flex-direction: column; justify-content: center; }
  .st-title {
    margin: 0 0 4px; font-family: var(--sans); font-weight: 700;
    font-size: 1.14rem; color: #fbfaf6; letter-spacing: -.01em; line-height: 1.3;
  }
  .locked .st-title { color: var(--ink-dim); font-weight: 600; }
  .st-mm {
    margin: 0 0 11px; font-family: var(--display); font-style: italic;
    font-size: 1.04rem; color: var(--ink-dim);
  }
  .locked .st-mm { color: var(--ink-faint); }

  .st-meta { display: flex; align-items: center; gap: 14px; }
  .st-alt {
    font-family: var(--mono); font-size: .66rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--accent); border: 1px solid rgba(92,200,232,.32);
    padding: 2px 9px; border-radius: 20px;
  }
  .st-locked { font-family: var(--mono); font-size: .74rem; letter-spacing: .05em; color: var(--ink-faint); }

  .st-go {
    display: flex; align-items: center; padding: 0 24px;
    font-size: 1.5rem; color: var(--amber); transition: transform .2s ease;
  }
  a.station-card:hover .st-go { transform: translateX(4px); }

  @media (max-width: 560px) {
    .st-badge { min-width: 64px; font-size: 2rem; }
    .st-go { display: none; }
  }
</style>
