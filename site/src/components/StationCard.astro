---
import RiskMeter from './RiskMeter.astro';

interface Props {
  station: number;
  title: string;
  mentalModel: string;
  teaser?: string;
  risk: number;
  altitude: string;
  status: 'published' | 'locked';
  href?: string;
  lang?: 'zh' | 'en';
}
const {
  station, title, mentalModel, teaser, risk, altitude, status, href, lang = 'zh',
} = Astro.props;
const locked = status === 'locked';
const Tag = locked ? 'div' : 'a';
const num = String(station).padStart(2, '0');
const t = lang === 'zh'
  ? { planned: '计划中', open: '阅读本篇' }
  : { planned: 'planned', open: 'read this stop' };
---
<Tag class:list={['station-card', { locked }]} href={locked ? undefined : href}>
  <span class="st-badge">{num}</span>
  <div class="st-body">
    <h3 class="st-title">{title}</h3>
    <p class="st-mm">{mentalModel}</p>
    {teaser && <p class="st-teaser">{teaser}</p>}
    <div class="st-meta">
      {locked ? (
        <span class="st-planned">□ {t.planned}</span>
      ) : (
        <Fragment>
          <span class="st-alt">{altitude}</span>
          <RiskMeter value={risk} lang={lang} />
          <span class="st-open">{t.open} →</span>
        </Fragment>
      )}
    </div>
  </div>
</Tag>

<style>
  .station-card {
    display: flex; align-items: stretch;
    border-radius: var(--radius);
    text-decoration: none;
    overflow: hidden;
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }
  /* 已发布 = 亮纸面、可点 */
  a.station-card {
    background: var(--panel);
    border: 1px solid var(--line-2);
    box-shadow: var(--shadow-card);
  }
  a.station-card:hover {
    transform: translateY(-3px);
    border-color: var(--signal);
    box-shadow: 0 20px 44px -24px rgba(206,67,38,.4);
  }

  /* 计划中 = 淡墨虚线、低调安静 */
  .station-card.locked {
    background: rgba(251,246,236,.32);
    border: 1px dashed var(--line-2);
    opacity: .82;
  }

  .st-badge {
    font-family: var(--display); font-weight: 600; font-size: 2.6rem; line-height: 1;
    display: flex; align-items: center; justify-content: center;
    min-width: 92px; color: var(--signal);
    border-right: 1px solid var(--line);
  }
  .locked .st-badge {
    color: var(--ink-faint); border-right: 1px dashed var(--line-2);
  }

  .st-body { padding: 17px 22px; flex: 1; display: flex; flex-direction: column; justify-content: center; min-width: 0; }
  .locked .st-body { padding: 14px 22px; }

  .st-title {
    margin: 0 0 4px; font-family: var(--display); font-weight: 600;
    font-size: 1.32rem; color: var(--ink); letter-spacing: -.01em; line-height: 1.22;
  }
  .locked .st-title { color: var(--ink-2); font-size: 1.18rem; }
  .st-mm {
    margin: 0 0 9px; font-family: var(--display); font-style: italic;
    font-size: 1.06rem; color: var(--signal-deep); line-height: 1.35;
  }
  .locked .st-mm { color: var(--ink-faint); font-size: .98rem; }
  .st-teaser {
    margin: 0 0 13px; font-size: .92rem; line-height: 1.6; color: var(--ink-2);
  }
  .locked .st-teaser { color: var(--ink-faint); font-size: .86rem; margin-bottom: 0; }

  .st-meta { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  .st-alt {
    font-family: var(--mono); font-size: .64rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--blue); border: 1px solid rgba(44,90,134,.3);
    padding: 2px 9px; border-radius: 20px;
  }
  .st-planned { font-family: var(--mono); font-size: .72rem; letter-spacing: .05em; color: var(--ink-faint); }
  .st-open {
    margin-left: auto; font-family: var(--mono); font-size: .72rem; letter-spacing: .04em;
    color: var(--signal); transition: transform .2s ease;
  }
  a.station-card:hover .st-open { transform: translateX(3px); }

  @media (max-width: 560px) {
    .st-badge { min-width: 60px; font-size: 2rem; }
    .st-open { margin-left: 0; }
  }
</style>
