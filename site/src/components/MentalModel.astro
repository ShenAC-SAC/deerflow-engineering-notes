---
// 内页开场大字:一句话心智模型
interface Props { label?: string; }
const { label = '心智模型' } = Astro.props;
---
<aside class="mental-model">
  <span class="mm-label">{label}</span>
  <p class="mm-text"><slot /></p>
</aside>

<style>
  .mental-model {
    margin: 8px 0 32px;
    padding: 18px 20px;
    background: linear-gradient(120deg, rgba(72,202,228,.14), rgba(72,202,228,.03));
    border: 1px solid rgba(72,202,228,.35);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius);
  }
  .mm-label {
    font-family: var(--mono); font-size: .7rem; letter-spacing: .14em;
    text-transform: uppercase; color: var(--accent);
  }
  .mm-text {
    margin: 6px 0 0; font-size: 1.5rem; font-weight: 800; color: #fff; line-height: 1.3;
  }
</style>
