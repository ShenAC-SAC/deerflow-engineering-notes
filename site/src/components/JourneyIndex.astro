---
import StationCard from './StationCard.astro';
import { JOURNEY, type Lang } from '../data/journey.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const stations = [...JOURNEY].sort((a, b) => a.station - b.station);

const copy = lang === 'zh'
  ? {
      kicker: 'deerflow · 源码阅读',
      title: '请求的旅程',
      sub: '跟着一个请求,走完它在 DeerFlow 里的一生。每一站是一张心智模型卡 —— 翻开就是一篇深读。',
      legend: '● = 碰它会炸什么(风险) · 🔒 = 还没修到这一站',
    }
  : {
      kicker: 'deerflow · source reading',
      title: "The Request's Journey",
      sub: 'Follow one request through its whole life inside DeerFlow. Each stop is a mental-model card — open it for the deep dive.',
      legend: '● = blast radius if you touch it (risk) · 🔒 = not paved yet',
    };
---
<section class="journey wrap">
  <p class="eyebrow">{copy.kicker}</p>
  <h1 class="journey-title">{copy.title}</h1>
  <p class="journey-sub">{copy.sub}</p>

  <ol class="spine">
    {stations.map((s) => (
      <li class="stop">
        <span class:list={['rail-node', { live: s.status === 'published' }]} aria-hidden="true"></span>
        <StationCard
          station={s.station}
          title={s.title[lang]}
          mentalModel={s.mentalModel[lang]}
          risk={s.risk}
          altitude={s.altitude}
          status={s.status}
          href={`/${lang}/journey/${s.station}`}
          lang={lang}
        />
      </li>
    ))}
  </ol>

  <p class="journey-legend eyebrow">{copy.legend}</p>
</section>

<style>
  .journey { padding-top: 66px; padding-bottom: 24px; }
  .journey-title {
    font-size: 3.5rem; margin: 10px 0 14px; letter-spacing: -.02em; line-height: 1.04;
  }
  .journey-sub {
    color: var(--ink-dim); max-width: 600px; margin: 0 0 46px; font-size: 1.06rem;
  }

  .spine { list-style: none; margin: 0; padding: 0; position: relative; }
  .stop { position: relative; padding-left: 70px; margin: 0 0 16px; }
  /* 逐段连接:每站从自己节点画到下一站节点,最后一站不画 → 全程贯通、不半路断 */
  .stop:not(:last-child)::before {
    content: ""; position: absolute; left: 29px; top: 36px;
    height: calc(100% + 16px); width: 2px; background: rgba(92,200,232,.26);
  }
  .rail-node {
    position: absolute; left: 22px; top: 28px;
    width: 16px; height: 16px; border-radius: 50%;
    background: var(--bg); border: 3px solid var(--accent);
    box-shadow: 0 0 0 4px rgba(92,200,232,.12);
  }
  /* 当前激活的站:暖琥珀 + 呼吸 */
  .rail-node.live {
    border-color: var(--amber);
    box-shadow: 0 0 0 4px rgba(244,161,74,.16), 0 0 18px rgba(244,161,74,.5);
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(244,161,74,.16), 0 0 14px rgba(244,161,74,.35); }
    50%      { box-shadow: 0 0 0 5px rgba(244,161,74,.22), 0 0 26px rgba(244,161,74,.65); }
  }
  .journey-legend { margin-top: 40px; text-align: center; }

  @media (max-width: 560px) {
    .journey-title { font-size: 2.3rem; }
    .stop { padding-left: 0; }
    .stop::before, .rail-node { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .rail-node.live { animation: none; }
  }
</style>
