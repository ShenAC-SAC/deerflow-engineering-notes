---
import StationCard from './StationCard.astro';
import { JOURNEY, type Lang } from '../data/journey.ts';
import { link } from '../utils/link.ts';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const stations = [...JOURNEY].sort((a, b) => a.station - b.station);
const published = stations.filter((s) => s.status === 'published');

const copy = lang === 'zh'
  ? {
      kicker: 'DeerFlow 2.0 · 工程源码手记',
      title: '从一句话到一次 Agent 运行',
      sub: '我们不按文件夹读源码，而是跟着一次真实请求往下走。源码很多，主线只有一条——我们就沿着它一路读到底。',
      progress: (n: number, p: number) => `主线 · ${n} 站 · 已发布 ${p} 篇`,
      legend: '■ 已发布，可阅读　·　□ 计划中　·　RISK = 改动影响半径',
    }
  : {
      kicker: 'DeerFlow 2.0 · engineering source notes',
      title: 'From a prompt to an agent run',
      sub: 'Instead of touring folders, we follow one real request through the runtime. The codebase is broad; the path through it is narrow — and we read straight down that path.',
      progress: (n: number, p: number) => `${n} stops · ${p} published`,
      legend: '■ published　·　□ planned　·　RISK = change blast radius',
    };
---
<section class="journey wrap">
  <header class="hero">
    <p class="eyebrow hero-kicker">{copy.kicker}</p>
    <h1 class="hero-title">{copy.title}</h1>
    <p class="hero-sub">{copy.sub}</p>
    <p class="progress-chip">{copy.progress(stations.length, published.length)}</p>
  </header>

  <ol class="stops">
    {stations.map((s) => {
      const live = s.status === 'published';
      return (
        <li class:list={['stop', { live, planned: !live }]}>
          <span class="rail-idx">{String(s.station).padStart(2, '0')}</span>
          <span class:list={['rail-node', { live }]} aria-hidden="true"></span>
          <StationCard
            station={s.station}
            title={s.title[lang]}
            mentalModel={s.mentalModel[lang]}
            teaser={s.teaser[lang]}
            risk={s.risk}
            altitude={s.altitude}
            status={s.status}
            href={link(`/${lang}/journey/${s.station}`)}
            lang={lang}
          />
        </li>
      );
    })}
  </ol>

  <p class="journey-legend eyebrow">{copy.legend}</p>
</section>

<style>
  .journey { padding-top: 60px; padding-bottom: 24px; }

  /* —— Hero —— */
  .hero { max-width: 640px; margin-bottom: 30px; }
  .hero-kicker { color: var(--blue); }
  .hero-title {
    font-size: 3.1rem; margin: 14px 0 16px; letter-spacing: -.02em; line-height: 1.06;
  }
  .hero-sub {
    color: var(--ink-2); margin: 0 0 22px; font-size: 1.08rem; line-height: 1.7;
  }
  .progress-chip {
    display: inline-block; margin: 0;
    font-family: var(--mono); font-size: .72rem; letter-spacing: .05em;
    color: var(--ink-faint);
    border: 1px solid var(--line); border-radius: 7px;
    padding: 4px 11px; background: var(--panel);
  }

  /* —— 旅程主线 —— */
  .stops { list-style: none; margin: 38px 0 0; padding: 0; position: relative; }
  .stop { position: relative; padding-left: 78px; margin: 0 0 14px; }

  /* 站序号(等宽,贴在主线左侧) */
  .rail-idx {
    position: absolute; left: 0; top: 30px;
    font-family: var(--mono); font-size: .72rem; letter-spacing: .02em;
    color: var(--ink-faint);
  }

  /* 主线:逐段连接,已发布段实线、计划段虚线 */
  .stop:not(:last-child)::before {
    content: ""; position: absolute; left: 47px; top: 38px;
    height: calc(100% + 14px); width: 2px;
  }
  .stop.live:not(:last-child)::before { background: var(--blue); opacity: .42; }
  .stop.planned:not(:last-child)::before {
    background: repeating-linear-gradient(
      to bottom, var(--line-2) 0 5px, transparent 5px 11px
    );
  }

  /* 节点:已发布=朱砂实心,计划=空心 */
  .rail-node {
    position: absolute; left: 41px; top: 30px;
    width: 13px; height: 13px; border-radius: 2px;
    background: var(--paper); border: 2px solid var(--line-2);
  }
  .rail-node.live {
    background: var(--signal); border-color: var(--signal);
    box-shadow: 0 0 0 4px var(--signal-wash);
  }

  .journey-legend { margin-top: 40px; text-align: center; line-height: 2; }

  @media (max-width: 560px) {
    .hero-title { font-size: 2.15rem; }
    .stop { padding-left: 0; }
    .stop::before, .rail-node, .rail-idx { display: none; }
  }
</style>
