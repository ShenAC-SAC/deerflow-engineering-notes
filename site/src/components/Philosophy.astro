---
// 工程设计哲学(一等公民):为什么这样设计、取舍在哪。
interface Props { title?: string; }
const { title = '工程设计哲学' } = Astro.props;
---
<aside class="philosophy">
  <header class="ph-head">
    <span class="ph-ico">🧭</span>
    <span class="ph-title">{title}</span>
  </header>
  <div class="ph-body"><slot /></div>
</aside>

<style>
  .philosophy {
    position: relative;
    margin: 30px 0;
    padding: 18px 20px 14px;
    background:
      linear-gradient(180deg, rgba(6,214,160,.08), rgba(6,214,160,.02));
    border: 1px solid rgba(6,214,160,.30);
    border-left: 4px solid var(--ok);
    border-radius: var(--radius);
  }
  .ph-head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .ph-ico { font-size: 1.1rem; }
  .ph-title {
    font-family: var(--mono); font-weight: 700; letter-spacing: .06em;
    color: var(--ok); text-transform: uppercase; font-size: .82rem;
  }
  .ph-body :global(p:first-child) { margin-top: 0; }
  .ph-body :global(p:last-child) { margin-bottom: 0; }
</style>
