---
// 工程设计哲学(一等公民):为什么这样设计、取舍在哪。
interface Props { title?: string; }
const { title = '工程设计哲学' } = Astro.props;
---
<aside class="philosophy">
  <header class="ph-head">
    <span class="ph-mark" aria-hidden="true">◆</span>
    <span class="ph-title">{title}</span>
  </header>
  <div class="ph-body"><slot /></div>
</aside>

<style>
  .philosophy {
    position: relative;
    margin: 32px 0;
    padding: 16px 20px 14px;
    background: var(--blue-wash);
    border: 1px solid rgba(44,90,134,.26);
    border-left: 3px solid var(--blue);
    border-radius: var(--radius);
  }
  .ph-head { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .ph-mark { color: var(--blue); font-size: .7rem; }
  .ph-title {
    font-family: var(--mono); font-weight: 600; letter-spacing: .12em;
    color: var(--blue-deep); text-transform: uppercase; font-size: .76rem;
  }
  .ph-body :global(p:first-child) { margin-top: 0; }
  .ph-body :global(p:last-child) { margin-bottom: 0; }
</style>
