---
// 流程/序列图:客户端 Mermaid 渲染(无需构建期 headless 浏览器)。
// 用法:<FlowDiagram chart={`graph TD; A-->B`} caption="..." />
// chart 走 prop(纯文本),避免 MDX 把图源当 markdown 解析。
interface Props { chart: string; caption?: string; }
const { chart, caption } = Astro.props;
---
<figure class="flow">
  <pre class="mermaid">{chart}</pre>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script>
  import mermaid from 'mermaid';
  mermaid.initialize({
    startOnLoad: false,
    theme: 'base',
    securityLevel: 'strict',
    themeVariables: {
      fontFamily: '"Spline Sans Mono", ui-monospace, Menlo, monospace',
      fontSize: '14px',
      background: '#0c121b',
      primaryColor: '#161f2b',        // 节点底
      primaryBorderColor: '#5cc8e8',  // 节点:冷蓝图描边(结构)
      primaryTextColor: '#ece7dd',    // 节点文字(暖纸)
      secondaryColor: '#161f2b',
      tertiaryColor: '#0c121b',
      lineColor: '#d98f48',           // 连线:暖琥珀(请求在流动)
      edgeLabelBackground: '#0e131b',
      clusterBkg: '#0c121b',
    },
  });
  const run = () => mermaid.run({ querySelector: '.mermaid' });
  if (document.readyState !== 'loading') run();
  else document.addEventListener('DOMContentLoaded', run);
</script>

<style>
  .flow {
    margin: 24px 0; padding: 14px;
    background: var(--bg-panel); border: 1px solid var(--bg-elev);
    border-radius: var(--radius); overflow-x: auto;
  }
  .flow .mermaid { background: none; border: none; padding: 0; text-align: center; }
  .flow figcaption {
    margin-top: 10px; text-align: center;
    font-family: var(--mono); font-size: .76rem; color: var(--ink-dim);
  }
</style>
