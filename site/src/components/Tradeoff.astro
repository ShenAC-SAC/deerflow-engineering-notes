---
// 取舍两栏:左=这样做 / 右=代价(用具名 slot: left / right)
interface Props { leftTitle?: string; rightTitle?: string; }
const { leftTitle = '这样做', rightTitle = '代价' } = Astro.props;
---
<div class="tradeoff">
  <div class="to-col to-left">
    <h4>{leftTitle}</h4>
    <slot name="left" />
  </div>
  <div class="to-col to-right">
    <h4>{rightTitle}</h4>
    <slot name="right" />
  </div>
</div>

<style>
  .tradeoff { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 26px 0; }
  .to-col { padding: 14px 16px; border-radius: var(--radius); border: 1px solid var(--line); background: var(--panel); }
  .to-left  { border-left: 3px solid var(--blue); }
  .to-right { border-left: 3px solid var(--signal); }
  .to-col h4 { margin: 0 0 6px; font-family: var(--mono); font-size: .76rem; letter-spacing: .04em; text-transform: uppercase; }
  .to-left h4  { color: var(--blue-deep); }
  .to-right h4 { color: var(--signal-deep); }
  .to-col :global(ul) { margin: 0; padding-left: 18px; }
  .to-col :global(li) { font-size: .9rem; line-height: 1.55; }
  @media (max-width: 560px) { .tradeoff { grid-template-columns: 1fr; } }
</style>
