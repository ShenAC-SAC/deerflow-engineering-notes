---
import '../styles/theme.css';
import { link, stripBase } from '../utils/link.ts';

interface Props {
  title: string;
  lang?: 'zh' | 'en';
  description?: string;
}
const { title, lang = 'zh', description = 'DeerFlow 源码阅读 · 可视化工程博客' } = Astro.props;

const other = lang === 'zh' ? 'en' : 'zh';
const altPath = link(stripBase(Astro.url.pathname).replace(/^\/(zh|en)/, `/${other}`));
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={link('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..600;1,9..144,400..500&family=Hanken+Grotesk:wght@400;500;600;700;800&family=Spline+Sans+Mono:ital,wght@0,400..600;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={link(`/${lang}/`)}>
          <span class="brand-main">deerflow</span>
          <span class="brand-sep">/</span>
          <span>source-reading</span>
        </a>
        <span class="spacer"></span>
        <a class="lang-switch" href={altPath}>
          {lang.toUpperCase()} → {other.toUpperCase()}
        </a>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      deerflow / source-reading · 源码阅读可视化教程 · pinned &amp; anchored
    </footer>
  </body>
</html>
