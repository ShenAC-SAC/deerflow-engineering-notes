---
import '../styles/theme.css';
import { link, stripBase } from '../utils/link.ts';

interface Props {
  title: string;
  lang?: 'zh' | 'en';
  description?: string;
}
const {
  title,
  lang = 'en',
  description = lang === 'zh'
    ? 'DeerFlow 源码阅读 · 可视化工程博客'
    : 'DeerFlow source-reading notes for understanding the Python agent runtime',
} = Astro.props;

const other = lang === 'zh' ? 'en' : 'zh';
const pathname = stripBase(Astro.url.pathname) || '/';
const toEnglishPath = (path: string): string => {
  if (path === '/' || path === '/zh' || path === '/zh/') return '/';
  if (path.startsWith('/zh/')) return path.replace(/^\/zh/, '/en');
  return path.startsWith('/en') ? path : `/en${path}`;
};
const toChinesePath = (path: string): string => {
  if (path === '/' || path === '/en' || path === '/en/') return '/zh/';
  if (path.startsWith('/en/')) return path.replace(/^\/en/, '/zh');
  return path.startsWith('/zh') ? path : `/zh${path}`;
};
const altPath = link(lang === 'zh' ? toEnglishPath(pathname) : toChinesePath(pathname));
const homePath = link(lang === 'zh' ? '/zh/' : '/');
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';
const footer = lang === 'zh'
  ? 'deerflow / source-reading · 源码阅读可视化教程 · pinned & anchored'
  : 'deerflow / source-reading · visual engineering notes · pinned & anchored';
---
<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={link('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..600;1,9..144,400..500&family=Hanken+Grotesk:wght@400;500;600;700;800&family=Spline+Sans+Mono:ital,wght@0,400..600;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a class="brand" href={homePath}>
          <span class="brand-main">deerflow</span>
          <span class="brand-sep">/</span>
          <span>source-reading</span>
        </a>
        <span class="spacer"></span>
        <a class="lang-switch" href={altPath}>
          {lang.toUpperCase()} → {other.toUpperCase()}
        </a>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      {footer}
    </footer>
  </body>
</html>
