---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import RiskMeter from '../components/RiskMeter.astro';
import MentalModel from '../components/MentalModel.astro';
import SourceRef from '../components/SourceRef.astro';
import { JOURNEY, type Lang, type Station } from '../data/journey.ts';
import { link } from '../utils/link.ts';

interface Props {
  lang: Lang;
  entry: CollectionEntry<'tutorials'>;
  meta: Station;
}
const { lang, entry, meta } = Astro.props;
const { title, sha, sourceRefs, station } = entry.data;

const ordered = [...JOURNEY].sort((a, b) => a.station - b.station);
const idx = ordered.findIndex((s) => s.station === station);
const prev = ordered[idx - 1];
const next = ordered[idx + 1];
const linkable = (s?: Station) => !!s && s.status === 'published';
const num = String(station).padStart(2, '0');

const t = lang === 'zh'
  ? { back: '← 返回主线', refs: '源码锚点', frame: `第 ${num} 站 · 已发布`, mm: '心智模型', next: '下一站', prev: '上一站' }
  : { back: '← the journey', refs: 'source anchors', frame: `stop ${num} · published`, mm: 'Mental model', next: 'next stop', prev: 'prev stop' };
---
<BaseLayout title={`${meta.title[lang]} · DeerFlow`} lang={lang}>
  <article class="tut wrap">
    <a class="tut-back" href={link(`/${lang}/`)}>{t.back}</a>

    <header class="tut-head">
      <div class="tut-badge">{num}</div>
      <div class="tut-headmeta">
        <p class="tut-frame eyebrow">{t.frame}</p>
        <h1 class="tut-title">{meta.title[lang]}</h1>
        <div class="tut-meta">
          <span class="tut-alt">{meta.altitude}</span>
          <RiskMeter value={meta.risk} lang={lang} />
        </div>
      </div>
    </header>

    <MentalModel label={t.mm}>{meta.mentalModel[lang]}</MentalModel>

    <div class="tut-refs">
      <span class="eyebrow tut-refs-label">{t.refs} · @{sha.slice(0, 7)}</span>
      <div class="tut-refs-list">
        {sourceRefs.map((f) => <SourceRef file={f} sha={sha} full />)}
      </div>
    </div>

    <div class="prose"><slot /></div>

    <nav class="tut-nav">
      {linkable(prev)
        ? <a class="nav-link" href={link(`/${lang}/journey/${prev.station}`)}><span class="nav-dir">{t.prev}</span><span class="nav-ttl">← {prev.title[lang]}</span></a>
        : <span class="nav-off">{prev ? `🔒 ${prev.title[lang]}` : ''}</span>}
      {linkable(next)
        ? <a class="nav-link nav-r" href={link(`/${lang}/journey/${next.station}`)}><span class="nav-dir">{t.next}</span><span class="nav-ttl">{next.title[lang]} →</span></a>
        : <span class="nav-off">{next ? `${next.title[lang]} 🔒` : ''}</span>}
    </nav>
  </article>
</BaseLayout>

<style>
  .tut { padding-top: 40px; padding-bottom: 24px; }
  .tut-back {
    font-family: var(--mono); font-size: .8rem; letter-spacing: .04em; color: var(--ink-faint);
  }
  .tut-back:hover { color: var(--signal); text-decoration: none; }

  .tut-head { display: flex; align-items: flex-start; gap: 20px; margin: 26px 0 6px; }
  /* 大号衬线站号,像一章的开篇数字 */
  .tut-badge {
    font-family: var(--display); font-weight: 600; font-size: 3.7rem; line-height: .9;
    flex: none; color: var(--signal);
  }
  .tut-frame { color: var(--ink-faint); margin: 0 0 6px; }
  .tut-title {
    margin: 0; font-size: 2.4rem; line-height: 1.1; letter-spacing: -.018em;
  }
  .tut-meta { display: flex; align-items: center; gap: 14px; margin-top: 12px; }
  .tut-alt {
    font-family: var(--mono); font-size: .66rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--blue); border: 1px solid rgba(44,90,134,.3); padding: 2px 9px; border-radius: 20px;
  }

  .tut-refs {
    margin: 26px 0 38px; padding: 14px 16px;
    background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius);
  }
  .tut-refs-label { color: var(--ink-faint); }
  .tut-refs-list { margin-top: 9px; }

  .prose { font-size: 1.06rem; }
  .prose :global(h2) { scroll-margin-top: 70px; }
  /* 首段首字下沉 = 手记感 */
  .prose :global(> p:first-of-type::first-letter) {
    font-family: var(--display); font-weight: 600; float: left;
    font-size: 3.2rem; line-height: .78; padding: 6px 12px 0 0; color: var(--signal);
  }

  .tut-nav {
    display: flex; justify-content: space-between; gap: 16px;
    margin-top: 64px; padding-top: 22px; border-top: 1px solid var(--line);
  }
  .nav-link { display: flex; flex-direction: column; gap: 3px; max-width: 46%; }
  .nav-link.nav-r { text-align: right; margin-left: auto; }
  .nav-dir {
    font-family: var(--mono); font-size: .66rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--ink-faint);
  }
  .nav-ttl { font-family: var(--display); font-size: 1.05rem; color: var(--blue); line-height: 1.25; }
  .nav-link:hover .nav-ttl { color: var(--signal); }
  .tut-nav .nav-off { font-family: var(--mono); font-size: .82rem; color: var(--ink-faint); align-self: center; }

  @media (max-width: 560px) {
    .tut-badge { font-size: 2.8rem; }
    .tut-title { font-size: 1.9rem; }
  }
</style>
