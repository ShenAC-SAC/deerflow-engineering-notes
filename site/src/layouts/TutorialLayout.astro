---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import RiskMeter from '../components/RiskMeter.astro';
import MentalModel from '../components/MentalModel.astro';
import SourceRef from '../components/SourceRef.astro';
import { JOURNEY, type Lang, type Station } from '../data/journey.ts';

interface Props {
  lang: Lang;
  entry: CollectionEntry<'tutorials'>;
  meta: Station;
}
const { lang, entry, meta } = Astro.props;
const { title, sha, sourceRefs, station } = entry.data;

const ordered = [...JOURNEY].sort((a, b) => a.station - b.station);
const idx = ordered.findIndex((s) => s.station === station);
const prev = ordered[idx - 1];
const next = ordered[idx + 1];
const linkable = (s?: Station) => !!s && s.status === 'published';

const t = lang === 'zh'
  ? { back: '← 旅程', refs: '源码锚点' }
  : { back: '← Journey', refs: 'Source anchors' };
---
<BaseLayout title={`${meta.title[lang]} · DeerFlow`} lang={lang}>
  <article class="tut wrap">
    <a class="tut-back" href={`/${lang}/`}>{t.back}</a>

    <header class="tut-head">
      <div class="tut-badge">{String(station).padStart(2, '0')}</div>
      <div class="tut-headmeta">
        <h1 class="tut-title">{meta.title[lang]}</h1>
        <div class="tut-meta">
          <span class="tut-alt">{meta.altitude}</span>
          <RiskMeter value={meta.risk} />
        </div>
      </div>
    </header>

    <MentalModel>{meta.mentalModel[lang]}</MentalModel>

    <div class="tut-refs">
      <span class="eyebrow">{t.refs} · @{sha.slice(0, 7)}</span>
      <div class="tut-refs-list">
        {sourceRefs.map((f) => <SourceRef file={f} sha={sha} full />)}
      </div>
    </div>

    <div class="prose"><slot /></div>

    <nav class="tut-nav">
      {linkable(prev)
        ? <a href={`/${lang}/journey/${prev.station}`}>← {prev.title[lang]}</a>
        : <span class="nav-off">{prev ? `🔒 ${prev.title[lang]}` : ''}</span>}
      {linkable(next)
        ? <a href={`/${lang}/journey/${next.station}`}>{next.title[lang]} →</a>
        : <span class="nav-off">{next ? `${next.title[lang]} 🔒` : ''}</span>}
    </nav>
  </article>
</BaseLayout>

<style>
  .tut { padding-top: 44px; padding-bottom: 24px; }
  .tut-back {
    font-family: var(--mono); font-size: .82rem; letter-spacing: .04em; color: var(--ink-dim);
  }
  .tut-back:hover { color: var(--amber); text-decoration: none; }

  .tut-head { display: flex; align-items: flex-start; gap: 18px; margin: 26px 0 6px; }
  /* 大号衬线站号,像一章的开篇数字 */
  .tut-badge {
    font-family: var(--display); font-weight: 600; font-size: 3.6rem; line-height: .9;
    flex: none; color: var(--amber);
    text-shadow: 0 0 30px rgba(244,161,74,.35);
  }
  .tut-title {
    margin: 0; font-size: 2.4rem; line-height: 1.1; letter-spacing: -.015em;
  }
  .tut-meta { display: flex; align-items: center; gap: 14px; margin-top: 10px; }
  .tut-alt {
    font-family: var(--mono); font-size: .68rem; letter-spacing: .14em; text-transform: uppercase;
    color: var(--accent); border: 1px solid rgba(92,200,232,.32); padding: 2px 9px; border-radius: 20px;
  }

  .tut-refs {
    margin: 24px 0 36px; padding: 14px 16px;
    background: rgba(255,255,255,.018); border: 1px solid var(--line); border-radius: var(--radius);
  }
  .tut-refs-list { margin-top: 9px; }

  .prose { font-size: 1.05rem; }
  .prose :global(h2) { scroll-margin-top: 70px; }
  /* 首段首字下沉 = 杂志感 */
  .prose :global(> p:first-of-type::first-letter) {
    font-family: var(--display); font-weight: 600; float: left;
    font-size: 3.1rem; line-height: .8; padding: 6px 12px 0 0; color: var(--amber);
  }

  .tut-nav {
    display: flex; justify-content: space-between; gap: 12px;
    margin-top: 64px; padding-top: 22px; border-top: 1px solid var(--line);
    font-family: var(--mono); font-size: .86rem;
  }
  .tut-nav a:hover { color: var(--amber); text-decoration: none; }
  .tut-nav .nav-off { color: var(--ink-faint); }
</style>
